{
  "name": "austerbitz",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:soldier-components": "node scripts/build-soldier-components.mjs --kit british-line-infantry && node scripts/slice-component-atlas.mjs",
    "build:poses": "npm run build:soldier-components && node scripts/build-pose-manifest.mjs",
    "draw:cuirassier-poses": "node scripts/draw-cuirassier-poses.mjs",
    "dev": "npm run build:poses && vite",
    "build": "npm run build:poses && tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  },
  "dependencies": {
    "gl-matrix": "^3.4.3"
  }
}
